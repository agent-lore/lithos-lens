# Lithos Lens multi-env Docker configuration.
# Copy to .env.dev or .env.prod and fill in values.
# Files matching .env.* (except .env.example) are gitignored.

# Human label surfaced to the running container (app code can read it).
LITHOS_LENS_ENVIRONMENT=dev

# Host path mounted at /data inside the container.
LITHOS_LENS_DATA_PATH=./data

# Container name — must be unique per environment so stacks can coexist.
LITHOS_LENS_CONTAINER_NAME=lithos-lens-dev

# Optional overrides.
# LITHOS_LENS_IMAGE=lithos-lens:dev
# LITHOS_LENS_UID=1000
# LITHOS_LENS_GID=1000
